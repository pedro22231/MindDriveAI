# ===========================================
# MindDriveAI - Configuracao de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha suas API keys.
# NUNCA commite o arquivo .env com suas chaves reais!

# ===========================================
# GOOGLE GEMINI API
# ===========================================
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
# Esta e a opcao recomendada - o nivel gratuito e generoso.
GEMINI_API_KEY=

# Alternativa (mesmo valor)
# GOOGLE_API_KEY=

# ===========================================
# OPENAI API (ChatGPT)
# ===========================================
# Obtenha sua chave em: https://platform.openai.com/api-keys
# Nota: OpenAI requer pagamento ou creditos.
OPENAI_API_KEY=

# ===========================================
# CONFIGURACOES OPCIONAIS
# ===========================================
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Porta do servidor web (padrao: 3000)
# PORT=3000
